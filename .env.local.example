# =============================================
# AI CODE AGENCY — Environment Variables
# Copy this file to .env.local and fill in values
# NEVER commit .env.local to git
# =============================================

# ----- APP -----
NEXT_PUBLIC_BASE_URL=http://localhost:3000
# Production: set to your real URL, e.g. https://aicodeagencywebsite.vercel.app
# If unset on Vercel, the app uses https://$VERCEL_URL for Stripe redirect URLs (no extra config needed).

# ----- STRIPE -----
# Get from: https://dashboard.stripe.com/apikeys
# Must be the SECRET key (sk_test_... / sk_live_...), not the publishable key (pk_...).
# On Vercel: Project → Settings → Environment Variables → add STRIPE_SECRET_KEY.
# Scope it to Production *and* Preview (or “All”) so preview URLs like *.vercel.app work too.
# Then redeploy. .env.local does not apply to Vercel.
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Stripe Webhook Secret (for verifying webhook events)
# Get from: https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=whsec_...

# Optional: Stripe Price IDs (from Dashboard → Products → Price ID, e.g. price_1ABC...)
# Omit these variables entirely to use dynamic Checkout prices from code (recommended to start).
# Never set placeholder values like "price_..." — invalid IDs cause checkout to fail.
# Use test-mode Price IDs with sk_test_ keys (and live Price IDs with sk_live_ keys).
# STRIPE_PRICE_TOURISM_CHATBOT=
# STRIPE_PRICE_VENDOR_DASHBOARD=
# STRIPE_PRICE_LEAD_SCRAPER=
# STRIPE_PRICE_AI_CONTENT=
# STRIPE_PRICE_AUTHORITY13=             # monthly subscription product in Stripe
# STRIPE_PRICE_AI_RECEPTIONIST=
# STRIPE_PRICE_CREATOR_MARKETPLACE=
# STRIPE_PRICE_AUCTION_PLATFORM=

# Bundle Price IDs (optional; same rules as above)
# STRIPE_PRICE_STARTER_BUNDLE=
# STRIPE_PRICE_BUSINESS_BUNDLE=
# STRIPE_PRICE_AGENCY_BUNDLE=

# ----- SUPABASE -----
# Get from: https://supabase.com/dashboard/project/[your-project]/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://[your-project-ref].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...   # Keep this secret — server-side only

# ----- RESEND -----
# Get from: https://resend.com/api-keys
# Verify domain aicodeagency.org in Resend; transactional senders use orders@ / noreply@;
# quote notifications go to info@aicodeagency.org (see src/lib/resend.ts).
RESEND_API_KEY=re_...
